# Copy to .env for local development (auto-loaded via python-dotenv).

# Upstream Hospital Directory API base URL.
UPSTREAM_BASE_URL=https://hospital-directory.onrender.com

# Max hospitals accepted per CSV upload (assignment constraint).
MAX_HOSPITALS=20

# Number of concurrent upstream create calls per bulk request.
# Keep modest to stay polite to the shared free-tier upstream.
BULK_CONCURRENCY=8

# Upstream HTTP timeouts (seconds). Read timeout is generous to absorb cold starts.
UPSTREAM_CONNECT_TIMEOUT=10
UPSTREAM_READ_TIMEOUT=60

# Retry policy for transient upstream errors (429/502/503/504 + connection errors).
UPSTREAM_MAX_RETRIES=3
UPSTREAM_BACKOFF_FACTOR=1.0

# If true, activate successfully-created hospitals even when some rows fail.
# Default false matches the literal spec (activate only when all succeed).
ACTIVATE_ON_PARTIAL=false

# Background worker threads for async jobs.
JOB_WORKERS=4

# Logging level.
LOG_LEVEL=INFO
